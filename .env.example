# ─────────────────────────────────────────────
#  Playlist-as-a-Service — Environment Config
# ─────────────────────────────────────────────

# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=change-me-to-a-random-secret-key-in-production

# Spotify API — create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_TOKEN_URL=https://accounts.spotify.com/api/token
SPOTIFY_API_BASE_URL=https://api.spotify.com/v1

# Database (SQLite for dev, swap to PostgreSQL for prod)
DATABASE_URL=sqlite+aiosqlite:///./playlist_service.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/playlist_service

# Redis (optional — set USE_REDIS=false to use in-memory cache)
USE_REDIS=false
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Logging
LOG_LEVEL=INFO
